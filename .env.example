# Borneo Tracker — API keys template
# Copy this file to ".env" and fill in real values. The real .env is git-ignored.
# Backend only. Never expose these in the React frontend (CORS + key leak).

# Global Forest Watch — forest cover, deforestation (header: x-api-key)
# Get it: https://data-api.globalforestwatch.org/  (POST /auth/token -> POST /auth/apikey)
GFW_API_KEY=

# BPS Indonesia WebAPI — Kalimantan 5-province statistics
# Get it: https://webapi.bps.go.id/developer/  (register -> create application)
BPS_API_KEY=

# NASA FIRMS — active fire hotspots (VIIRS)
# Get it: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# WAQI / aqicn — air quality PM2.5 (cities)
# Get it: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Keyless sources (no key needed): data.gov.my / OpenDOSM, World Bank, UN SDG API

# ── News Tracker (AR-3) ──────────────────────────────────────────────────────
# AI digest — Google AI Studio (free tier). Used by digest_news.py.
GEMINI_API_KEY=
# Optional fallback key(s) — MUST be from a DIFFERENT Google project to help
# (quota is per-project, not per-key). digest_news.py rotates to the next on a 429.
# GEMINI_API_KEY_2=

# Supabase (live news store). Frontend reads live published news from here.
# VITE_* are exposed in the browser bundle — safe: the anon key is gated by RLS
# (anon can only read published rows). Leave BLANK to run on the local mock store.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Pipeline write path (local + GitHub Actions). SERVICE ROLE key = SECRET,
# server-side only, never shipped to the browser. Used by digest_news.py to
# upsert drafts. In production this lives in GitHub Actions secrets.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
