# Borneo Tracker — API keys template
# Copy this file to ".env" and fill in real values. The real .env is git-ignored.
# API keys below are backend only. Never rename them with VITE_ or expose them in React.

# Global Forest Watch — forest cover, deforestation (header: x-api-key)
# Get it: https://data-api.globalforestwatch.org/  (POST /auth/token -> POST /auth/apikey)
GFW_API_KEY=

# BPS Indonesia WebAPI — Kalimantan 5-province statistics
# Get it: https://webapi.bps.go.id/developer/  (register -> create application)
BPS_API_KEY=

# NASA FIRMS — active fire hotspots (VIIRS)
# Get it: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# WAQI / aqicn — air quality PM2.5 (cities)
# Get it: https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Frontend-only prototype flag (never put secrets in VITE_* values).
# Local Vite development keeps Community writes enabled automatically.
# Production builds require an explicit opt-in until the Community backend exists.
VITE_ENABLE_COMMUNITY_WRITES=false

# Keyless sources (no key needed): data.gov.my / OpenDOSM, World Bank, UN SDG API
