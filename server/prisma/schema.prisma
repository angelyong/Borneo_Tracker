generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  SENT
  DEAD
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  email                   String                   @db.VarChar(254)
  emailNormalized         String                   @unique(map: "users_email_normalized_key") @map("email_normalized") @db.VarChar(254)
  passwordHash            String                   @map("password_hash")
  firstName               String                   @map("first_name") @db.VarChar(100)
  lastName                String                   @map("last_name") @db.VarChar(100)
  role                    UserRole                 @default(USER)
  status                  UserStatus               @default(PENDING)
  emailVerifiedAt         DateTime?                @map("email_verified_at") @db.Timestamptz(3)
  passwordChangedAt       DateTime                 @default(now()) @map("password_changed_at") @db.Timestamptz(3)
  authVersion             BigInt                   @default(1) @map("auth_version")
  lastLoginAt             DateTime?                @map("last_login_at") @db.Timestamptz(3)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  profile                 UserProfile?
  sessions                Session[]
  verificationTokens      EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  emailChangeRequests     EmailChangeRequest[]
  auditEvents             AuthAuditEvent[]

  @@map("users")
}

model UserProfile {
  userId           String   @id @map("user_id") @db.Uuid
  phoneCountryCode String?  @map("phone_country_code") @db.VarChar(8)
  phoneNumber      String?  @map("phone_number") @db.VarChar(32)
  addressLine      String?  @map("address_line") @db.VarChar(200)
  city             String?  @db.VarChar(100)
  state            String?  @db.VarChar(100)
  postalCode       String?  @map("postal_code") @db.VarChar(20)
  version          Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique(map: "sessions_token_hash_key") @map("token_hash") @db.Char(64)
  authVersion BigInt    @map("auth_version")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(3)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  ipHash      String?   @map("ip_hash") @db.Char(64)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt], map: "sessions_user_active_idx")
  @@map("sessions")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique(map: "email_verification_tokens_hash_key") @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt], map: "email_verification_tokens_user_idx")
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique(map: "password_reset_tokens_hash_key") @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt], map: "password_reset_tokens_user_idx")
  @@map("password_reset_tokens")
}

model EmailChangeRequest {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  newEmail           String    @map("new_email") @db.VarChar(254)
  newEmailNormalized String    @map("new_email_normalized") @db.VarChar(254)
  tokenHash          String    @unique(map: "email_change_requests_hash_key") @map("token_hash") @db.Char(64)
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt             DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt], map: "email_change_requests_user_idx")
  @@map("email_change_requests")
}

model AuthAuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(80)
  result    String   @db.VarChar(40)
  requestId String   @map("request_id") @db.VarChar(100)
  ipHash    String?  @map("ip_hash") @db.Char(64)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt], map: "auth_audit_event_type_idx")
  @@index([userId, createdAt], map: "auth_audit_user_idx")
  @@map("auth_audit_events")
}

model EmailOutbox {
  id                String       @id @default(uuid()) @db.Uuid
  eventType         String       @map("event_type") @db.VarChar(80)
  recipient         String       @db.VarChar(254)
  encryptedPayload  String?      @map("encrypted_payload")
  keyVersion        String       @map("key_version") @db.VarChar(20)
  dedupeKey         String       @unique(map: "email_outbox_dedupe_key_key") @map("dedupe_key") @db.VarChar(150)
  status            OutboxStatus @default(PENDING)
  attemptCount      Int          @default(0) @map("attempt_count")
  nextAttemptAt     DateTime     @default(now()) @map("next_attempt_at") @db.Timestamptz(3)
  lockedAt          DateTime?    @map("locked_at") @db.Timestamptz(3)
  claimId           String?      @map("claim_id") @db.Uuid
  sentAt            DateTime?    @map("sent_at") @db.Timestamptz(3)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  providerMessageId String?      @map("provider_message_id") @db.VarChar(255)
  lastErrorCode     String?      @map("last_error_code") @db.VarChar(80)

  @@index([status, nextAttemptAt], map: "email_outbox_ready_idx")
  @@index([claimId], map: "email_outbox_claim_idx")
  @@map("email_outbox")
}

model EmailSuppression {
  id                  String    @id @default(uuid()) @db.Uuid
  recipientLookupHmac String    @unique(map: "email_suppressions_recipient_lookup_key") @map("recipient_lookup_hmac") @db.Char(64)
  encryptedRecipient  String    @map("encrypted_recipient")
  keyVersion           String    @map("key_version") @db.VarChar(20)
  reason               String    @db.VarChar(80)
  source               String    @db.VarChar(80)
  providerEventId      String    @unique(map: "email_suppressions_provider_event_key") @map("provider_event_id") @db.VarChar(255)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  clearedAt            DateTime? @map("cleared_at") @db.Timestamptz(3)

  @@index([recipientLookupHmac, clearedAt], map: "email_suppressions_active_idx")
  @@map("email_suppressions")
}

model RateLimitBucket {
  key         String   @id @db.VarChar(180)
  count       Int      @default(0)
  windowStart DateTime @map("window_start") @db.Timestamptz(3)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(3)

  @@index([expiresAt], map: "rate_limit_buckets_expiry_idx")
  @@map("rate_limit_buckets")
}
