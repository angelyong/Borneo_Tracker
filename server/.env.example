NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://borneo_app:local_borneo_password@localhost:5433/borneo_tracker_app?schema=public
APP_PUBLIC_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
CSRF_SECRET=replace-with-at-least-32-random-characters
OUTBOX_ENCRYPTION_KEYRING={"active":"v1","keys":{"v1":"replace-with-base64-encoded-32-byte-key"}}
FINGERPRINT_HMAC_KEY=replace-with-base64-encoded-32-byte-key
SUPPRESSION_LOOKUP_HMAC_KEYRING={"active":"v1","keys":{"v1":"replace-with-base64-encoded-32-byte-key"}}
PII_ENCRYPTION_KEYRING={"active":"v1","keys":{"v1":"replace-with-base64-encoded-32-byte-key"}}
EMAIL_PROVIDER=smtp
EMAIL_FROM=Borneo Tracker <no-reply@borneotracker.local>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
LOG_LEVEL=info
PUBLIC_REGISTRATION_ENABLED=true
